# Lambda deployment artifacts (libraries installed via pip --target)
backend/lambda/*/
backend/lambda/*.dist-info/
backend/lambda/*.zip
backend/lambda_deployment.zip
backend/lambda/*.so
 
# Keep the actual Lambda code tracked
!backend/lambda/chat.py
 
# Terraform state and cache
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfplan
 
# Python cache
__pycache__/
*.pyc
 
# AWS credentials (just in case)
.env
*.pem
.aws/
 
# OS junk
.DS_Store
Thumbs.db